@page "/carrinho"
@rendermode InteractiveServer
@using System.Security.Claims
@using GameHub.Domain.Entities
@inject CarrinhoService Cart
@inject IPedidoService PedidoService
@inject IAluguelService AluguelService
@inject IEnderecoService EnderecoService

<PageTitle>Carrinho — GameHub</PageTitle>

<div class="pg-section-head">
    <h1>Meu <span class="gold">Carrinho</span></h1>
</div>

@if (sucesso is not null)
{
    <div class="pg-toast">✅ @sucesso</div>
}
@if (erro is not null)
{
    <div class="pg-empty" style="border-color:#b32121;color:#ff8a8a;">⚠️ @erro</div>
}

@if (Cart.Itens.Count == 0)
{
    <div class="pg-empty">
        Seu carrinho está vazio. <a href="catalogo">Ir ao catálogo</a>
    </div>
}
else
{
    <table class="pg-table">
        <thead>
            <tr>
                <th>Jogo</th>
                <th>Tipo</th>
                <th>Qtd / Dias</th>
                <th>Preço unit.</th>
                <th>Subtotal</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Cart.Itens)
            {
                <tr>
                    <td>@item.Titulo</td>
                    <td>@(item.Tipo == TipoAquisicao.Compra ? "Compra" : "Aluguel")</td>
                    <td>@(item.Tipo == TipoAquisicao.Compra ? $"{item.Quantidade}x" : $"{item.DiasAluguel} dia(s)")</td>
                    <td>R$ @item.PrecoUnitario.ToString("N2")</td>
                    <td>R$ @item.Subtotal.ToString("N2")</td>
                    <td style="text-align:right;">
                        <button class="pg-btn pg-btn-ghost" @onclick="() => Cart.Remover(item)">Remover</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @* ---- Endereço de entrega (aparece quando há itens de COMPRA no carrinho) ---- *@
    @if (Cart.Itens.Any(i => i.Tipo == TipoAquisicao.Compra))
    {
        <div style="margin:1.25rem 0;">
            <h3 class="gold">Endereço de entrega</h3>
            @if (enderecos is null)
            {
                <p class="pg-muted">Carregando endereços...</p>
            }
            else if (enderecos.Count == 0)
            {
                <p class="pg-muted">
                    Você ainda não tem endereço. <a href="minha-conta/enderecos">Cadastrar endereço</a>
                    (necessário para finalizar a compra).
                </p>
            }
            else
            {
                <select class="pg-input" @bind="enderecoSelecionadoId" style="max-width:520px;">
                    @foreach (var e in enderecos)
                    {
                        <option value="@e.Id">
                            @e.Logradouro, @e.Numero — @e.Bairro, @e.Cidade/@e.Uf (@e.Cep)@(e.Principal ? " ★" : "")
                        </option>
                    }
                </select>
            }
        </div>
    }

    <div class="pg-cart-footer">
        <button class="pg-btn pg-btn-ghost" @onclick="Cart.Limpar" disabled="@processando">Esvaziar carrinho</button>
        <div class="pg-cart-total">
            Total: <span class="gold">R$ @Cart.ValorTotal.ToString("N2")</span>
        </div>
        <button class="pg-btn pg-btn-gold" @onclick="Finalizar" disabled="@(processando || Cart.Itens.Count == 0)">
            @(processando ? "Processando..." : "Finalizar")
        </button>
    </div>
}

@code {
    // Recebe o estado de autenticação (quem está logado) via cascata.
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string? sucesso;
    private string? erro;
    private bool processando;

    // Agenda do cliente (para escolher o endereço de entrega) + o id escolhido.
    private List<Endereco>? enderecos;
    private int enderecoSelecionadoId;

    protected override async Task OnInitializedAsync()
    {
        var user = AuthState is null ? null : (await AuthState).User;
        var userId = user?.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) { enderecos = new(); return; }

        enderecos = await EnderecoService.ListarDoUsuarioAsync(userId);
        // Default: o endereço principal (ou o primeiro), se houver.
        var padrao = enderecos.FirstOrDefault(e => e.Principal) ?? enderecos.FirstOrDefault();
        if (padrao is not null) enderecoSelecionadoId = padrao.Id;
    }

    private async Task Finalizar()
    {
        sucesso = null;
        erro = null;

        // 1) Precisa estar logado (pedido/aluguel pertencem a um cliente).
        var user = AuthState is null ? null : (await AuthState).User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            erro = "Entre na sua conta para finalizar.";
            return;
        }

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        var nome = user.Identity?.Name ?? "Cliente";
        if (string.IsNullOrEmpty(userId))
        {
            erro = "Não consegui identificar sua conta. Tente entrar novamente.";
            return;
        }

        // 2) Separa os itens do carrinho por tipo.
        var itensCompra = Cart.Itens
            .Where(i => i.Tipo == TipoAquisicao.Compra)
            .Select(i => new ItemCompra(i.JogoId, i.Quantidade))
            .ToList();

        var itensAluguel = Cart.Itens
            .Where(i => i.Tipo == TipoAquisicao.Aluguel)
            .Select(i => new ItemAluguel(i.JogoId, i.DiasAluguel))
            .ToList();

        // 2b) Endereço de entrega: só exigido quando há COMPRA (o aluguel não gera Pedido).
        EnderecoEntrega? enderecoEntrega = null;
        if (itensCompra.Count > 0)
        {
            var escolhido = enderecos?.FirstOrDefault(e => e.Id == enderecoSelecionadoId);
            if (escolhido is null)
            {
                erro = "Escolha um endereço de entrega (ou cadastre em Meus Endereços).";
                return;
            }
            // SNAPSHOT: copiamos os campos do endereço escolhido (NÃO referenciamos a agenda) —
            // assim o pedido guarda o endereço "congelado", mesmo que a agenda mude depois (§5.1).
            enderecoEntrega = new EnderecoEntrega
            {
                Cep = escolhido.Cep,
                Logradouro = escolhido.Logradouro,
                Numero = escolhido.Numero,
                Complemento = escolhido.Complemento,
                Bairro = escolhido.Bairro,
                Cidade = escolhido.Cidade,
                Uf = escolhido.Uf
            };
        }

        processando = true;
        try
        {
            var partes = new List<string>();

            // 3a) Compra → cria um Pedido (transação própria).
            if (itensCompra.Count > 0)
            {
                var pedido = await PedidoService.FinalizarCompraAsync(userId, nome, itensCompra, enderecoEntrega);
                partes.Add($"Pedido #{pedido.Id} (R$ {pedido.ValorTotal:N2})");
            }

            // 3b) Aluguel → cria os Aluguéis (transação própria).
            if (itensAluguel.Count > 0)
            {
                var alugueis = await AluguelService.FinalizarAluguelAsync(userId, nome, itensAluguel);
                var totalAluguel = alugueis.Sum(a => a.ValorTotal);
                partes.Add($"{alugueis.Count} aluguel(éis) (R$ {totalAluguel:N2})");
            }

            // 4) Deu certo: esvazia o carrinho e monta a mensagem.
            Cart.Limpar();
            sucesso = "Feito! " + string.Join(" e ", partes) + " — aguardando pagamento.";
        }
        catch (Exception ex)
        {
            // Se um serviço lançou, a transação dele já fez Rollback.
            erro = ex.Message;
        }
        finally
        {
            processando = false;
        }
    }
}
