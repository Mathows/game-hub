@page "/admin/cupons"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using GameHub.Domain.Entities
@using GameHub.Domain.Enums
@using GameHub.Infrastructure.Data
@inject GameHubDbContext Db

<PageTitle>Cupons — Admin GameHub</PageTitle>

<div class="pg-section-head">
    <h1>Gerenciar <span class="gold">Cupons</span></h1>
    <a class="pg-btn pg-btn-outline" href="admin/jogos">← Jogos</a>
</div>

@if (mensagem is not null)
{
    <div class="pg-toast">@mensagem</div>
}

<div style="display:flex; gap:2rem; flex-wrap:wrap; align-items:flex-start;">

    @* ---- Cupons cadastrados ---- *@
    <div style="flex:2 1 420px;">
        @if (cupons is null)
        {
            <p class="pg-muted">Carregando...</p>
        }
        else if (cupons.Count == 0)
        {
            <div class="pg-empty">Nenhum cupom cadastrado.</div>
        }
        else
        {
            <table class="pg-table">
                <thead>
                    <tr><th>Código</th><th>Desconto</th><th>Validade</th><th>Usos</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var c in cupons)
                    {
                        <tr>
                            <td><strong>@c.Codigo</strong></td>
                            <td>@(c.Tipo == TipoDesconto.Percentual ? $"{c.Valor:N0}%" : $"R$ {c.Valor:N2}")</td>
                            <td>até @c.Validade.ToString("dd/MM/yy HH:mm")</td>
                            <td>@c.Usos@(c.LimiteUsos is null ? "" : $" / {c.LimiteUsos}")</td>
                            <td>
                                @if (c.ValidoEm(DateTime.Now))
                                {
                                    <span class="gold">✓ Válido</span>
                                }
                                else if (!c.Ativo)
                                {
                                    <span class="pg-muted">Desativado</span>
                                }
                                else if (c.LimiteUsos is not null && c.Usos >= c.LimiteUsos)
                                {
                                    <span class="pg-muted">Esgotado</span>
                                }
                                else
                                {
                                    <span class="pg-muted">Expirado</span>
                                }
                            </td>
                            <td style="text-align:right;">
                                @if (c.Ativo)
                                {
                                    <button class="pg-btn pg-btn-ghost" @onclick="() => Desativar(c.Id)">Desativar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ---- Novo cupom ---- *@
    <div style="flex:1 1 300px;">
        <h2 class="gold">Novo cupom</h2>

        <label>Código</label>
        <input class="pg-input" @bind="form.Codigo" placeholder="Ex.: NATAL10" style="text-transform:uppercase;" />

        <label>Tipo de desconto</label>
        <select class="pg-input" @bind="form.Tipo">
            <option value="@TipoDesconto.Percentual">Percentual (%)</option>
            <option value="@TipoDesconto.ValorFixo">Valor fixo (R$)</option>
        </select>

        <label>@(form.Tipo == TipoDesconto.Percentual ? "Percentual (ex.: 10 = 10%)" : "Valor em R$")</label>
        <input class="pg-input" type="number" step="0.01" min="0" @bind="form.Valor" />

        <label>Válido até</label>
        <input class="pg-input" type="date" @bind="form.Validade" />

        <label>Limite de usos (vazio = ilimitado)</label>
        <input class="pg-input" type="number" min="1" @bind="form.LimiteUsos" />

        <button class="pg-btn pg-btn-gold" style="margin-top:1rem;" @onclick="Salvar" disabled="@ocupado">
            Criar cupom
        </button>
    </div>
</div>

@code {
    private List<Cupom>? cupons;
    private string? mensagem;
    private bool ocupado;
    private FormModel form = new();

    protected override async Task OnInitializedAsync() => await CarregarAsync();

    private async Task CarregarAsync() =>
        cupons = await Db.Cupons.AsNoTracking().OrderByDescending(c => c.Id).ToListAsync();

    private async Task Salvar()
    {
        mensagem = null;
        var codigo = form.Codigo.Trim().ToUpperInvariant();

        if (codigo.Length < 3) { mensagem = "⚠️ O código precisa de pelo menos 3 caracteres."; return; }
        if (form.Valor <= 0) { mensagem = "⚠️ Informe o valor do desconto."; return; }
        if (form.Tipo == TipoDesconto.Percentual && form.Valor > 100)
        { mensagem = "⚠️ Percentual não pode passar de 100%."; return; }

        ocupado = true;
        try
        {
            Db.Cupons.Add(new Cupom
            {
                Codigo = codigo,
                Tipo = form.Tipo,
                Valor = form.Valor,
                Validade = form.Validade.Date.AddDays(1).AddSeconds(-1),   // vale até 23:59:59
                LimiteUsos = form.LimiteUsos,
                Ativo = true
            });
            await Db.SaveChangesAsync();   // auditoria automática carimba quem criou
            mensagem = $"✅ Cupom {codigo} criado.";
            form = new();
            await CarregarAsync();
        }
        catch (DbUpdateException)
        {
            // O índice ÚNICO (UX_Cupom_Codigo) barrou código repetido — o schema protegendo.
            mensagem = $"⚠️ Já existe um cupom com o código {codigo}.";
            Db.ChangeTracker.Clear();
        }
        catch (Exception ex)
        {
            mensagem = "⚠️ Erro ao salvar: " + ex.Message;
        }
        finally { ocupado = false; }
    }

    private async Task Desativar(int id)
    {
        var cupom = await Db.Cupons.FirstOrDefaultAsync(c => c.Id == id);
        if (cupom is null) return;
        cupom.Ativo = false;
        await Db.SaveChangesAsync();
        mensagem = $"Cupom {cupom.Codigo} desativado.";
        await CarregarAsync();
    }

    private sealed class FormModel
    {
        public string Codigo { get; set; } = "";
        public TipoDesconto Tipo { get; set; } = TipoDesconto.Percentual;
        public decimal Valor { get; set; }
        public DateTime Validade { get; set; } = DateTime.Today.AddDays(30);
        public int? LimiteUsos { get; set; }
    }
}
