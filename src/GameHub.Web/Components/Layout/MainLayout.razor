@inherits LayoutComponentBase

<div class="pg-app">

    <header class="pg-header">
        <div class="pg-header-inner">
            <a class="pg-logo" href="/">
                <span class="pg-logo-icon">🎮</span>
                <span>GAME<span class="gold">HUB</span></span>
            </a>

            <nav class="pg-nav">
                <NavLink class="pg-nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
                <NavLink class="pg-nav-link" href="catalogo">Comprar</NavLink>
                <NavLink class="pg-nav-link" href="catalogo">Alugar</NavLink>
                <NavLink class="pg-nav-link" href="trocas">Trocar</NavLink>
                <NavLink class="pg-nav-link" href="admin/jogos">Admin</NavLink>
            </nav>

            <div class="pg-header-actions">
                @* Ilha interativa: o selo roda no circuito e lê o mesmo carrinho Scoped. *@
                <CarrinhoBadge @rendermode="InteractiveServer" />
                <AuthorizeView>
                    <Authorized>
                        <NotificacaoListener @rendermode="InteractiveServer" />
                        <a class="pg-nav-link" href="meus-pedidos">Meus Pedidos</a>
                        <a class="pg-nav-link" href="minha-conta/enderecos">Endereços</a>
                        <a class="pg-nav-link" href="Account/Manage">@context.User.Identity?.Name</a>
                        @* Sair: logout é um POST (com antiforgery) pra Account/Logout — nunca um link GET,
                           senão qualquer site conseguiria te deslogar. ReturnUrl vazio volta pra home. *@
                        <form action="Account/Logout" method="post" class="pg-logout-form">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="" />
                            <button type="submit" class="pg-nav-link pg-logout-btn"
                                    style="background:none;border:none;cursor:pointer;font:inherit;">Sair</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a class="pg-nav-link" href="Account/Login">Entrar</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="pg-main">
        @Body
    </main>

    <footer class="pg-footer">
        <div class="pg-footer-inner">
            © 2026 GameHub — Seu hub completo para jogos: compre, venda, alugue e troque.
        </div>
    </footer>

</div>

<div id="blazor-error-ui" data-nosnippet>
    Ocorreu um erro inesperado.
    <a href="." class="reload">Recarregar</a>
    <span class="dismiss">🗙</span>
</div>
