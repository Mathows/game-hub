@using System.Security.Claims
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Nav
@implements IAsyncDisposable

@* Ilha que fica "ouvindo" notificações do servidor e mostra toasts no canto.
   Conecta ao NotificacaoHub e se registra com o id do usuário logado. *@

@if (notificacoes.Count > 0)
{
    <div class="pg-notifs">
        @foreach (var n in notificacoes)
        {
            <div class="pg-notif">
                <span>@n.Texto</span>
                <button class="pg-notif-x" @onclick="() => Remover(n)">✕</button>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private HubConnection? hub;
    private readonly List<Notif> notificacoes = new();
    private sealed record Notif(Guid Id, string Texto);

    protected override async Task OnInitializedAsync()
    {
        var user = AuthState is null ? null : (await AuthState).User;
        var userId = user?.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;   // só para logados

        hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/notificacao"))
            .WithAutomaticReconnect()
            .Build();

        hub.On<string>("Notificacao", texto =>
        {
            notificacoes.Add(new Notif(Guid.NewGuid(), texto));
            return InvokeAsync(StateHasChanged);
        });

        await hub.StartAsync();
        await hub.InvokeAsync("Registrar", userId);
    }

    private void Remover(Notif n) => notificacoes.Remove(n);

    public async ValueTask DisposeAsync()
    {
        if (hub is not null) await hub.DisposeAsync();
    }
}
